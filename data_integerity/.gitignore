build/
dist/
*.egg-info/
.Python
pip-wheel-metadata/

# Logs
*.log

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# pytest cache
.pytest_cache/

# Coverage reports
.coverage
htmlcov/

# Docker overrides (if any)
docker-compose.override.yml
