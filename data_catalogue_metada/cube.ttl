ex:participantsCount a qb:MeasureProperty ;
    rdfs:subPropertyOf sdmx-m:obsValue ;
    skos:prefLabel "Participants count"@en .

ex:program a qb:DimensionProperty,
        rdf:Property ;
    rdfs:subPropertyOf sdmx-d:refStatisticalConcept ;
    skos:prefLabel "Program"@en .

ex:programScheme a skos:ConceptScheme ;
    skos:prefLabel "Program"@en .

ex:provider a qb:DimensionProperty,
        rdf:Property ;
    rdfs:subPropertyOf sdmx-d:refArea ;
    skos:prefLabel "Provider"@en .

ex:providerScheme a skos:ConceptScheme ;
    skos:prefLabel "Provider"@en .

